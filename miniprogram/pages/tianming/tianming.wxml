<view class="page">
  <view class="page-hd" style="padding-top: {{statusBarHeight}}px; margin-top: 20rpx;">
    <text class="page-hd-title">令牌殿</text>
    <text class="page-hd-sub">通知令牌 · 一令一报</text>
  </view>

  <view wx:if="{{!loading && !isBound}}" class="tip-box">
    <text class="tip-icon">⚔</text>
    <text class="tip-text">尚未绑定江湖身份</text>
    <text class="tip-sub">绑定账号后，方可领取令牌\n获取通知资格</text>
    <view class="btn btn-primary" bindtap="goToBind">前往身份牌</view>
  </view>

  <view wx:if="{{isBound}}" class="content">
    <view class="quota-card card">
      <view class="quota-row">
        <view class="quota-badge invite">邀</view>
        <view class="quota-info">
          <text class="quota-name">邀约令</text>
          <text class="quota-desc">江湖人士向你发起的组队邀请</text>
        </view>
        <text class="quota-count">{{quotas.invite}}</text>
      </view>
      <view class="divider"></view>
      <view class="quota-row">
        <view class="quota-badge full">满</view>
        <view class="quota-info">
          <text class="quota-name">满员令</text>
          <text class="quota-desc">你的队伍已满员时通知队长</text>
        </view>
        <text class="quota-count">{{quotas.full}}</text>
      </view>
      <view class="divider"></view>
      <view class="quota-row">
        <view class="quota-badge remind">鸣</view>
        <view class="quota-info">
          <text class="quota-name">开本令</text>
          <text class="quota-desc">开本前二十分钟提醒全体</text>
        </view>
        <text class="quota-count">{{quotas.remind}}</text>
      </view>
    </view>

    <view class="tip-card card">
      <text class="tip-card-text">⚔ 每次点击按钮弹出授权窗口，全部点「允许」即得三枚令牌。每轮领取3次，共三轮。</text>
    </view>

    <!-- 轮次进度 -->
    <view wx:if="{{!allComplete}}" class="round-wrap">
      <view class="round-dots">
        <view class="round-dot {{currentRound >= 1 ? 'active' : ''}} {{currentRound > 1 || (currentRound === 1 && roundComplete) ? 'done' : ''}}"></view>
        <view class="round-dot {{currentRound >= 2 ? 'active' : ''}} {{currentRound > 2 || (currentRound === 2 && roundComplete) ? 'done' : ''}}"></view>
        <view class="round-dot {{currentRound >= 3 ? 'active' : ''}} {{currentRound === 3 && roundComplete ? 'done' : ''}}"></view>
      </view>
      <text class="round-label">第{{currentRound}}轮 · {{roundDone}}/3次</text>
    </view>

    <view wx:if="{{allComplete}}" class="session-tip">
      ✓ 三轮领取完毕，共得 <text class="session-count">{{totalGained}}</text> 枚
    </view>

    <!-- 操作按钮 -->
    <view
      class="btn btn-primary {{(getting || allComplete) ? 'disabled' : ''}}"
      style="margin: 0 0 20rpx"
      bindtap="onGetQuota"
    >
      <block wx:if="{{getting}}">弹窗中，请点击允许…</block>
      <block wx:elif="{{allComplete}}">✓ 三轮领取完毕</block>
      <block wx:elif="{{roundComplete}}">⚔ 再领一次（第{{currentRound + 1}}轮）</block>
      <block wx:else>⚔ 领取令牌（第{{currentRound}}轮 {{roundDone + 1}}/3）</block>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
