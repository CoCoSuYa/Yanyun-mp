<view class="logs-page">
  <view class="logs-header">
    <text class="logs-title">字体加载日志</text>
    <view class="logs-actions">
      <button class="btn-refresh" bindtap="refresh">刷新</button>
      <button class="btn-clear" bindtap="clearLogs">清空</button>
    </view>
  </view>
  
  <view class="logs-list">
    <view wx:if="{{logs.length === 0}}" class="logs-empty">
      暂无日志，请重启小程序
    </view>
    
    <view wx:for="{{logs}}" wx:key="index" class="log-item">
      <text class="log-text">{{item}}</text>
    </view>
  </view>
</view>
