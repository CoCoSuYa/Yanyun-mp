.logs-page {
  min-height: 100vh;
  background: #120b05;
  padding: 20rpx;
}

.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #1e1208;
  border: 1rpx solid rgba(200,168,75,.2);
  border-radius: 12rpx;
}

.logs-title {
  font-size: 32rpx;
  color: #f0d882;
  font-weight: 700;
}

.logs-actions {
  display: flex;
  gap: 10rpx;
}

.btn-refresh, .btn-clear {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(200,168,75,.3);
  background: rgba(200,168,75,.1);
  color: #c8a84b;
}

.logs-list {
  background: #1e1208;
  border: 1rpx solid rgba(200,168,75,.2);
  border-radius: 12rpx;
  padding: 20rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.logs-empty {
  text-align: center;
  color: #8a7050;
  padding: 60rpx 20rpx;
  font-size: 28rpx;
}

.log-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(200,168,75,.1);
}

.log-item:last-child {
  border-bottom: none;
}

.log-text {
  font-size: 24rpx;
  color: #e8d8b0;
  word-break: break-all;
  font-family: monospace;
}
