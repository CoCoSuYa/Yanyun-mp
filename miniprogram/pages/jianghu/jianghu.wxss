.page { 
  background: var(--bg); 
  min-height: 100vh;
  /* 使用网络加载的楷�?*/
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}
.content { padding: 0 24rpx; }
.content .card { margin-bottom: 24rpx; }

.site-card { text-align: center; }
.site-title { 
  display: block; 
  font-size: 40rpx; 
  color: var(--gold-light); 
  /* 使用网络加载的楷�?*/
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important; 
  font-weight: 700; 
  letter-spacing: 4rpx; 
  margin-bottom: 8rpx; 
}
.site-sub   { display: block; font-size: 22rpx; color: var(--text-muted); letter-spacing: 2rpx; margin-bottom: 24rpx; }
.url-box { background: rgba(0,0,0,.3); border: 1rpx solid var(--border); border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 24rpx; }
.url-text { font-size: 24rpx; color: var(--gold); word-break: break-all; }

.info-card { }
.info-title { 
  display: block; 
  font-size: 28rpx; 
  color: var(--gold-light); 
  /* 使用网络加载的楷�?*/
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important; 
  margin-bottom: 16rpx; 
}
.info-step  { display: block; font-size: 26rpx; color: var(--text-sec); margin-bottom: 8rpx; }
.info-body  { display: block; font-size: 24rpx; color: var(--text-muted); line-height: 1.8; }
