.page { 
  background: var(--bg); 
  min-height: 100vh;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}
.content { padding: 0 24rpx; }
.content .card { margin-bottom: 24rpx; }

.bound-label { display: block; font-size: 22rpx; color: var(--text-muted); margin-bottom: 12rpx; letter-spacing: 2rpx; }
.bound-name  { 
  display: block; 
  font-size: 40rpx; 
  color: var(--gold-light); 
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important; 
  font-weight: 700; 
  margin-bottom: 12rpx; 
}
.bound-tags  { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 20rpx; }
.bound-tag   { font-size: 22rpx; color: var(--text-muted); background: rgba(200,168,75,.1); border: 1rpx solid var(--border); border-radius: 8rpx; padding: 4rpx 16rpx; }
.bound-tag.guild { color: var(--gold); border-color: rgba(200,168,75,.4); }
/* 统计条 */
.stats-strip {
  display: flex;
  gap: 20rpx;
  margin: 32rpx 0;
}
.stat-card {
  flex: 1;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}
.stat-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}
.stat-number {
  font-size: 52rpx;
  color: var(--gold-light);
  font-weight: 700;
  line-height: 1;
}
.stat-unit {
  font-size: 24rpx;
  color: var(--text-sec);
}
.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
}

.bound-status { display: flex; align-items: center; gap: 10rpx; }
.status-dot  { font-size: 20rpx; color: #4a9a4a; }
.status-text { font-size: 24rpx; color: var(--text-muted); }

.form-intro { display: block; font-size: 24rpx; color: var(--text-muted); margin-bottom: 28rpx; line-height: 1.6; }
.form-item  { margin-bottom: 20rpx; }
.form-label { display: block; font-size: 24rpx; color: var(--text-muted); margin-bottom: 10rpx; }
.form-err   { display: block; font-size: 24rpx; color: #e05050; margin-top: 12rpx; }
.form-hint  { display: block; font-size: 20rpx; color: var(--text-muted); margin-top: 6rpx; opacity: 0.7; }
.info-text  { display: block; font-size: 22rpx; color: var(--text-muted); line-height: 1.8; }
.req        { color: #e05050; font-size: 22rpx; }

/* 注册弹窗 */
.reg-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.72);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 底部向上偏移 tab 栏高度，让弹窗视觉上居中于可用区域 */
  padding: 32rpx 24rpx 132rpx;
  box-sizing: border-box;
}
.reg-panel {
  width: 100%;
  background: linear-gradient(180deg, #281a0c, #1e1208);
  border: 1rpx solid var(--border-hi);
  border-radius: 24rpx;
  padding: 40rpx 32rpx 40rpx;
  max-height: 78vh;
  overflow-y: auto;
  box-sizing: border-box;
}
.reg-title {
  display: block;
  font-size: 36rpx;
  color: var(--gold-light);
  font-weight: 700;
  margin-bottom: 8rpx;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}
.reg-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 28rpx;
}
.reg-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.reg-btns .btn { flex: 1; text-align: center; }

/* ===== 签到按钮（右下角固定） ===== */
.sign-btn-wrap {
  position: fixed;
  right: 32rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #8B4513, #5D2E0C);
  border: 2rpx solid var(--gold);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.5);
}
.sign-btn-icon { font-size: 36rpx; line-height: 1; }
.sign-btn-text {
  font-size: 18rpx; color: var(--gold-light); font-weight: 700;
  margin-top: 4rpx; letter-spacing: 1rpx;
}

/* ===== 签到成功弹层 ===== */
.sign-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1100;
  display: flex; align-items: center; justify-content: center;
}
.sign-success-box {
  background: linear-gradient(135deg, #1e1208, #2a1a0a);
  border: 2rpx solid var(--gold);
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.8);
  animation: signPop 0.5s ease;
}
@keyframes signPop {
  0%   { transform: scale(0.5); opacity: 0; }
  50%  { transform: scale(1.08); }
  100% { transform: scale(1); opacity: 1; }
}
.sign-success-icon { display: block; font-size: 80rpx; margin-bottom: 24rpx; }
.sign-success-title {
  display: block; font-size: 44rpx; color: var(--gold-light);
  font-weight: 700; margin-bottom: 16rpx; letter-spacing: 4rpx;
}
.sign-success-detail {
  display: block; font-size: 28rpx; color: var(--text); margin-bottom: 24rpx;
}
.sign-success-count {
  display: block; font-size: 24rpx; color: var(--text-sec);
}
