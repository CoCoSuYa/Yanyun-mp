/* 全局 CSS 变量 · 古风暗金主题（与网站一致） */
page {
  --bg:           #120b05;
  --bg-card:      #1e1208;
  --bg-card2:     #251708;
  --gold:         #c8a84b;
  --gold-light:   #f0d882;
  --red:          #8a2020;
  --text:         #e8d8b0;
  --text-sec:     #c8b080;
  --text-muted:   #8a7050;
  --border:       rgba(200,168,75,.2);
  --border-hi:    rgba(200,168,75,.5);

  background: var(--bg);
  color: var(--text);
  /* 使用系统默认字体 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 确保所有元素都使用系统字体 */
view, text, button, input, textarea, picker-view, rich-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
}

/* 通用按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  letter-spacing: 2rpx;
  border: none;
}
.btn::after { border: none; }
.btn-primary {
  background: rgba(200, 168, 75, 0.1);
  border: 1rpx solid rgba(200, 168, 75, 0.4);
  color: var(--gold-light);
}
.btn-ghost {
  background: transparent;
  border: 1rpx solid var(--border-hi);
  color: var(--gold);
}
.btn-danger {
  background: rgba(138, 32, 32, 0.15);
  border: 1rpx solid rgba(138, 32, 32, 0.4);
  color: #e05050;
}
.btn.disabled {
  opacity: .5;
  pointer-events: none;
}

/* 页头 */
.page-hd {
  padding: 48rpx 32rpx 80rpx; /* 增加底部间距，让内容不要太贴近标题 */
  text-align: center;
}
.page-hd-title {
  display: block;
  font-size: 48rpx;
  color: var(--gold-light);
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.page-hd-sub {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 4rpx 0;
}

/* 安全底部 */
.safe-bottom { height: 120rpx; }

/* 表单输入框 */
.form-input {
  background: rgba(255,255,255,.08);
  border: 1rpx solid var(--border-hi);
  border-radius: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  color: var(--text);
  font-size: 28rpx;
  font-family: -apple-system, sans-serif;
  width: 100%;
  box-sizing: border-box;
}
