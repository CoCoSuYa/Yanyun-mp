<view
  class="float-btn {{expanded ? 'float-expanded' : ''}} {{invites.length > 0 ? 'has-invite' : ''}}"
  bindtap="onFloatTap"
>
  <text class="float-char">游</text>
  <view wx:if="{{invites.length > 0}}" class="float-badge">{{invites.length > 9 ? '9+' : invites.length}}</view>
</view>

<view wx:if="{{panelVisible}}" class="panel-overlay" catchtap="closePanel">
  <view class="invite-panel" catchtap="">
    <view class="panel-hd">
      <text class="panel-title">⚔ 江湖邀约</text>
      <text class="panel-close" bindtap="closePanel">⚔</text>
    </view>

    <view wx:if="{{loading}}" class="panel-loading">
      <text>加载中…</text>
    </view>

    <view wx:elif="{{invites.length === 0}}" class="panel-empty">
      <text>暂无邀约，静候佳音</text>
    </view>

    <scroll-view wx:else scroll-y class="panel-list">
      <view wx:for="{{invites}}" wx:key="id" class="invite-card">
        <view class="invite-from">
          <text class="invite-from-name">{{item.fromGameName}}</text>
          <text class="invite-from-label"> 邀您入队</text>
        </view>
        <view class="invite-row">
          <text class="invite-label">副本</text>
          <text class="invite-val">{{item.teamType}}</text>
        </view>
        <view wx:if="{{item.teamPurpose}}" class="invite-row">
          <text class="invite-label">备注</text>
          <text class="invite-val">{{item.teamPurpose}}</text>
        </view>
        <view class="invite-row">
          <text class="invite-label">时间</text>
          <text class="invite-val">{{item.teamTimeStr}}</text>
        </view>
        <view class="invite-row">
          <text class="invite-label">人数</text>
          <text class="invite-val">{{item.memberCount}}/{{item.maxMembers}}</text>
        </view>
        <view class="invite-actions">
          <button
            class="btn-accept {{item._joining ? 'btn-loading' : ''}}"
            data-id="{{item.id}}"
            data-teamid="{{item.teamId}}"
            bindtap="onAccept"
            disabled="{{item._joining}}"
          >{{item._joining ? '入队中…' : '接受邀约'}}</button>
          <button class="btn-reject" data-id="{{item.id}}" bindtap="onReject">拒绝</button>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
