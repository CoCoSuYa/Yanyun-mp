/* 全屏的运动区域层，设置 pointer-events: none 避免阻挡底层页面点击 */
.bgm-area {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 1000;
}

/* 可拖动的实际音乐容器 */
.bgm-player {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  pointer-events: auto;
}

/* 内部负责动画和样式的实体（隔离 movable-view 的 transform） */
.bgm-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(20, 10, 5, 0.4);
  border: 1rpx solid rgba(200, 168, 75, 0.3);
  border-radius: 50%;
  font-size: 32rpx;
  color: var(--gold-light);
  filter: grayscale(1);
  transition: filter 0.3s, border-color 0.3s, box-shadow 0.3s;
  box-sizing: border-box;
}

.bgm-inner.playing {
  filter: grayscale(0);
  border-color: rgba(200, 168, 75, 0.8);
  animation: spin 5s linear infinite;
  box-shadow: 0 0 12rpx rgba(200, 168, 75, 0.4);
}

@keyframes spin {
  100% { transform: rotate(360deg); }
}
