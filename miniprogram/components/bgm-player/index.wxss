/* bgm-player 可拖动悬浮音乐播放器 */

/* movable-area 覆盖全屏但不拦截下层事件 */
.move-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  pointer-events: none;
}

/* movable-view 是实际的播放器 UI */
.bgm-bar {
  display: flex;
  align-items: center;
  background: rgba(26, 15, 8, 0.88);
  border-radius: 28rpx;
  padding: 6rpx 14rpx;
  gap: 6rpx;
  backdrop-filter: blur(8px);
  pointer-events: auto;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  width: auto;
  height: auto;
}

.bgm-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.bgm-icon {
  font-size: 24rpx;
  color: #f0d882;
  line-height: 1;
}

.bgm-name-wrap {
  overflow: hidden;
  flex-shrink: 1;
  max-width: 200rpx;
  position: relative;
}

.bgm-name {
  display: block;
  font-size: 22rpx;
  color: #c8a84b;
  white-space: nowrap;
  letter-spacing: 1rpx;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}

/* 曲名滚动动画 */
.bgm-name.marquee {
  animation: marquee 6s linear infinite;
}
@keyframes marquee {
  0%   { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}