/* ===== bgm 悬浮播放器 ===== */
.bgm-bar {
  position: fixed;
  display: flex;
  align-items: center;
  background: rgba(26, 15, 8, 0.88);
  border-radius: 28rpx;
  padding: 6rpx 14rpx;
  gap: 6rpx;
  backdrop-filter: blur(8px);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.4);
  z-index: 999;
  transition: box-shadow 0.2s;
}
.bgm-bar.dragging {
  box-shadow: 0 4rpx 24rpx rgba(200, 168, 75, 0.3);
}

.bgm-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
  transition: transform 0.15s ease, background 0.15s ease;
}
.bgm-btn-active {
  transform: scale(0.8);
  background: rgba(240, 216, 130, 0.25);
}

/* 播放（三角形） */
.icon-play {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 14rpx solid #f0d882;
  margin-left: 3rpx;
}

/* 暂停（两竖条） */
.icon-pause {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.pause-bar {
  width: 4rpx;
  height: 16rpx;
  background: #f0d882;
  border-radius: 2rpx;
}

/* 切歌（三角 + 竖条） */
.icon-next {
  display: flex;
  align-items: center;
  gap: 2rpx;
}
.next-tri {
  width: 0;
  height: 0;
  border-top: 7rpx solid transparent;
  border-bottom: 7rpx solid transparent;
  border-left: 12rpx solid #f0d882;
}
.next-bar {
  width: 3rpx;
  height: 14rpx;
  background: #f0d882;
  border-radius: 2rpx;
}

.bgm-name-wrap {
  overflow: hidden;
  flex-shrink: 1;
  max-width: 160rpx;
}
.bgm-name-inner {
  display: inline-flex;
  white-space: nowrap;
  animation: marquee-scroll 10s linear infinite;
}
.bgm-name {
  display: inline-block;
  font-size: 20rpx;
  color: #c8a84b;
  white-space: nowrap;
  padding-right: 1.5em;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}
@keyframes marquee-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== 底部 tab 栏 ===== */
.tabbar {
  display: flex;
  height: 100rpx;
  background: #1a0f08;
  border-top: 1rpx solid rgba(200,168,75,.3);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}
.tab-icon {
  font-size: 32rpx;
  color: #8a7050;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
  font-weight: 700;
  line-height: 1;
}
.tab-text {
  font-size: 20rpx;
  color: #8a7050;
  letter-spacing: 1rpx;
  font-family: 'STKaiti', 'KaiTi', 'SimKai', 'FangSong', 'STFangsong', serif !important;
}
.tab-item.active .tab-icon,
.tab-item.active .tab-text {
  color: #f0d882;
}
